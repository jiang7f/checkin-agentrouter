# AgentRouter browser-profile accounts.
#
# Each name maps to a local browser profile created with:
#   checkin-agentrouter add <name>
#
# Keep names generic in committed examples. Put your real account names only in local .env.
AGENTROUTER_ACCOUNTS=["main"]

# Optional concurrency controls. The defaults are conservative for accounts sharing one public IP.
# CHECKIN_CONCURRENCY=3
# CHECKIN_OAUTH_CONCURRENCY=2

# Optional notification webhook.
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/replace-with-your-token
# ALWAYS_NOTIFY=false

# Optional proxy settings.
# AgentRouter usually needs a working proxy for GitHub OAuth in some local networks.
# CHECKIN_PROXY_URL=http://127.0.0.1:7890
# PROXY_SUBSCRIPTION_URL=https://example.com/mihomo.yaml

# Optional browser/profile settings.
# CHECKIN_BROWSER_PROFILE_DIR=.browser_profiles
# CHECKIN_HEADLESS=true
# CHECKIN_HUMANIZE=true
# CHECKIN_HUMANIZE_AGENTROUTER=true
# CHECKIN_WAIT_TIMEOUT_MS=60000
# CLOAKBROWSER_BINARY_PATH=/path/to/browser

# Optional local state locations.
# CHECKIN_LAST_SESSIONS_FILE=last_sessions.json
# CHECKIN_SCREENSHOT_DIR=checkin_screenshots

# Optional debug mode. Debug screenshots stay local and are ignored by Git.
# DEBUG_MODE=false
